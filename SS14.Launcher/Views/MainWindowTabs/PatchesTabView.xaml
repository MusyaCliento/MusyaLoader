<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mainWindowTabs="clr-namespace:SS14.Launcher.ViewModels.MainWindowTabs"
             xmlns:loc="clr-namespace:SS14.Launcher.Localization"
             xmlns:conv="clr-namespace:SS14.Launcher.Converters"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="560"
             x:Class="SS14.Launcher.Views.MainWindowTabs.PatchesTabView"
             Name="PatchesTab">

  <UserControl.Resources>
    <conv:PathToFileNameConverter x:Key="PathToFileNameConverter" />
    <conv:BooleanToPreloadConverter x:Key="BooleanToPreloadConverter" />
    <conv:AssemblyToVersionConverter x:Key="AssemblyToVersionConverter" />
    <conv:PatchTypeTooltipConverter x:Key="PatchTypeTooltipConverter" />
    <conv:IconPathToImageConverter x:Key="IconPathToImageConverter" />

    <DataTemplate x:Key="PatchTileTemplate">
      <Border Classes="patch-card">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Classes="tile-icon-shell" VerticalAlignment="Top">
            <Image Source="{Binding IconPath, Converter={StaticResource IconPathToImageConverter}}"
                   Width="42"
                   Height="42"
                   Stretch="Uniform" />
          </Border>

          <StackPanel Grid.Column="1" Spacing="4" Margin="10,0,0,0">
            <TextBlock Text="{Binding Name}"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1" />

            <TextBlock Classes="SubText" TextTrimming="CharacterEllipsis" MaxLines="1">
              <Run Text="{Binding Asmpath, Converter={StaticResource PathToFileNameConverter}}" />
              <Run Text="  " />
              <Run Text="{Binding Asm, Converter={StaticResource AssemblyToVersionConverter}, FallbackValue='v?'}" />
            </TextBlock>

            <ToggleButton Command="{Binding DataContext.EnableRefreshCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                          Content="{loc:Loc marsey-Button-Toggle}"
                          Height="26"
                          HorizontalAlignment="Left"
                          CommandParameter="{Binding}" />
          </StackPanel>

          <Image Grid.Column="2"
                 Classes="info-icon"
                 Source="avares://SS14.Launcher/Assets/marsey-icons/info.png"
                 Width="18"
                 Height="18"
                 Margin="10,0,0,0"
                 VerticalAlignment="Top"
                 ToolTip.Tip="{Binding ., Converter={StaticResource PatchTypeTooltipConverter}}" />
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="ResTileTemplate">
      <Border Classes="resource-card">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Classes="tile-icon-shell" VerticalAlignment="Top">
            <Image Source="{Binding IconPath, Converter={StaticResource IconPathToImageConverter}}"
                   Width="42"
                   Height="42"
                   Stretch="Uniform" />
          </Border>

          <StackPanel Grid.Column="1" Spacing="6" Margin="10,0,0,0">
            <TextBlock Text="{Binding Name}"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1" />

            <StackPanel Orientation="Horizontal" Spacing="6">
              <ToggleButton Command="{Binding DataContext.EnableRefreshCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            IsChecked="{Binding Enabled, Mode=TwoWay}"
                            Content="{loc:Loc marsey-Button-Toggle}"
                            CommandParameter="{Binding}"
                            Height="26" />
              <Button Command="{Binding DataContext.MoveResourcePackUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}"
                      Content="Up"
                      Height="26"
                      MinWidth="44" />
              <Button Command="{Binding DataContext.MoveResourcePackDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}"
                      Content="Down"
                      Height="26"
                      MinWidth="56" />
            </StackPanel>
          </StackPanel>

          <Image Grid.Column="2"
                 Classes="info-icon"
                 Source="avares://SS14.Launcher/Assets/marsey-icons/info.png"
                 Width="18"
                 Height="18"
                 Margin="10,0,0,0"
                 VerticalAlignment="Top"
                 ToolTip.Tip="{Binding ., Converter={StaticResource PatchTypeTooltipConverter}}" />
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.column-header">
      <Setter Property="Foreground" Value="{DynamicResource ThemeSubTextBrush}" />
      <Setter Property="Margin" Value="6,0,0,6" />
    </Style>

    <Style Selector="Border.list-right">
      <Setter Property="Margin" Value="10,0,0,0" />
    </Style>

    <Style Selector="Border.patch-card">
      <Setter Property="Padding" Value="10" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="{DynamicResource ThemePopupBackgroundColor}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.resource-card">
      <Setter Property="Padding" Value="10" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="{DynamicResource ThemePopupBackgroundColor}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.list-column">
      <Setter Property="Padding" Value="8" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="{DynamicResource ThemeBackgroundColor}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="Border.tile-icon-shell">
      <Setter Property="Padding" Value="4" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Background" Value="#22000000" />
      <Setter Property="Width" Value="50" />
      <Setter Property="Height" Value="50" />
    </Style>

    <Style Selector="Image.info-icon">
      <Setter Property="Opacity" Value="0.65" />
    </Style>

    <Style Selector="Image.info-icon:pointerover">
      <Setter Property="Opacity" Value="1" />
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <mainWindowTabs:PatchesTabViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="*,Auto" Margin="8">
    <TabControl Grid.Row="0">
      <TabItem Header="{loc:Loc marsey-Header-Patches}">
        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*" Margin="0,8,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="column-header" Text="{loc:Loc marsey-Enabled}" />
          <TextBlock Grid.Row="0" Grid.Column="1" Classes="column-header" Margin="16,0,0,6" Text="{loc:Loc marsey-Disabled}" />

          <Border Grid.Row="1" Grid.Column="0" Classes="list-column">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding SubverterPatchesEnabled}" Name="SubverterPatchListEnabled">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <StaticResource ResourceKey="PatchTileTemplate" />
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <Border Grid.Row="1" Grid.Column="1" Classes="list-column list-right">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding SubverterPatchesDisabled}" Name="SubverterPatchListDisabled">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <StaticResource ResourceKey="PatchTileTemplate" />
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="{loc:Loc marsey-Header-ResourcePacks}" IsVisible="{Binding ShowRPacks}">
        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*" Margin="0,8,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="column-header" Text="{loc:Loc marsey-Enabled}" />
          <TextBlock Grid.Row="0" Grid.Column="1" Classes="column-header" Margin="16,0,0,6" Text="{loc:Loc marsey-Disabled}" />

          <Border Grid.Row="1" Grid.Column="0" Classes="list-column">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding ResourcePacksEnabled}" Name="ResourcePackListEnabled">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <StaticResource ResourceKey="ResTileTemplate" />
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <Border Grid.Row="1" Grid.Column="1" Classes="list-column list-right">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding ResourcePacksDisabled}" Name="ResourcePackListDisabled">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <StaticResource ResourceKey="ResTileTemplate" />
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
      <Border Grid.Column="0"
              Padding="10,8"
              CornerRadius="8"
              Background="{DynamicResource ThemePopupBackgroundColor}">
        <TextBlock Text="{loc:Loc marsey-Patches-Unsandboxed}"
                   Classes="SubText"
                   FontWeight="Bold"
                   TextWrapping="Wrap" />
      </Border>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" Margin="10,0,0,0">
        <Button Content="{loc:Loc marsey-OpenModDir}" Command="{Binding OpenPatchDirectoryCommand}" Height="30" />
        <Button Content="{loc:Loc marsey-RecheckMods}" Command="{Binding ReloadModsCommand}" Height="30" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
